# ChiWi Environment Configuration

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_WEBHOOK_URL=https://your-server.com/api/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=generate_a_random_secret_here
TELEGRAM_MESSAGE_MAX_AGE_SECONDS=120
TELEGRAM_RATE_LIMIT_PER_MINUTE=20

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=chiwi

# Redis
REDIS_URL=redis://localhost:6379

# Application
LOG_LEVEL=INFO
PII_MASK_ENABLED=true

# Business timezone — used for day-boundary math (reports, budgets,
# resolving "hôm nay"/"tuần này"). Storage stays in UTC.

# Categories — path to a JSON file with spending categories used by the
# Tagging Agent and the category seed. Leave empty to use config/categories.json.
USER_PROFILES_FILE=/data/user_profiles.json
